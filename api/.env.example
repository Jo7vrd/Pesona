# ---- Wajib ----
DATABASE_URL=postgres://user:password@localhost:5432/keikecil?sslmode=disable
JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter

# ---- Aplikasi ----
APP_ENV=development            # development | production
PORT=8080
CORS_ORIGINS=http://localhost:3000

# ---- Revalidasi cache Next.js (opsional) ----
REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=samakan-dengan-env-frontend

# ---- Cloudflare R2 (kosongkan untuk simpan foto di disk lokal) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=                 # mis. https://aset.keikecil.id

# ---- Seed (go run ./cmd/seed) ----
SEED_ADMIN_EMAIL=admin@keikecil.id
SEED_ADMIN_PASSWORD=KeiKecil#2026
SEED_ADMIN_NAMA=Admin Desa
